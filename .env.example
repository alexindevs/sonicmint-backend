# App
NODE_ENV=development
PORT=3001

# Database — update with your local credentials
DATABASE_URL="postgresql://sonicmint_dev:pass1234@localhost:5433/sonicmint_poc"

# JWT — generate strong secrets before production
JWT_ACCESS_SECRET=dev_access_secret_change_in_production
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production

# Redis (BullMQ) — required for audio processing queue
REDIS_URL=redis://localhost:6379

# AWS S3 — leave blank for local dev without audio uploads
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_AUDIO=sonicmint-audio
# CDN_BASE_URL=https://cdn.sonicmint.io
# Stripe — leave blank until M4
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# AI — Gemini / Lyria
GEMINI_API_KEY=

# Revenue
ROYALTY_RATE_GBP=0.004
PLATFORM_FEE_PCT=15

# Cloudflare — leave blank until M6
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
